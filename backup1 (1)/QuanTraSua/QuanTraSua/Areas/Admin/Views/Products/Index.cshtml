@model IEnumerable<QuanTraSua.Models.Product>

@{
    ViewData["Title"] = "Quản lý Món";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-uppercase" style="color: #5d4037;">🧋 Quản lý Món</h2>
        <a asp-action="Create" asp-controller="Product" class="btn btn-success btn-lg shadow-sm rounded-pill px-4 py-2 fw-bold" style="background-color: #C89F7C; border: none;">
            ➕ Thêm món mới
        </a>
    </div>

    <div class="row g-4">
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden hover-shadow" style="transition: all 0.3s;">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height: 200px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="bi bi-cup-hot-fill fs-1 text-muted"></i>
                            </div>
                        }
                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold mb-2">@item.Name</h5>
                            @{
                                string desc = item.Description;
                                if (!string.IsNullOrEmpty(desc) && desc.Length > 100)
                                {
                                    desc = desc.Substring(0, 100) + "...";
                                }
                            }
                            <p class="card-text text-muted small mb-3">@desc</p>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="h4 fw-bold text-danger mb-0">@String.Format("{0:N0}", item.Price)đ</span>
                            </div>
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-controller="Product" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm flex-fill rounded-pill">
                                    <i class="bi bi-eye"></i> Xem
                                </a>
                                <a asp-action="Edit" asp-controller="Product" asp-route-id="@item.Id" class="btn btn-warning btn-sm flex-fill rounded-pill">
                                    <i class="bi bi-pencil"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-controller="Product" asp-route-id="@item.Id" class="btn btn-danger btn-sm flex-fill rounded-pill">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="text-center py-5">
                    <i class="bi bi-cup-straw fs-1 text-muted mb-3"></i>
                    <h4 class="text-muted">Chưa có món nào</h4>
                    <p class="text-muted">Thêm món đầu tiên để bắt đầu!</p>
                    <a asp-action="Create" asp-controller="Product" class="btn btn-success shadow-sm rounded-pill px-4 py-2 fw-bold" style="background-color: #C89F7C; border: none;">
                        ➕ Thêm món ngay
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important;
    }
</style>
