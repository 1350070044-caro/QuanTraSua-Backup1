@model QuanTraSua.Models.Product

@{
    ViewData["Title"] = "Chi tiết Món";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded-4 shadow-sm mb-4" style="max-height: 400px; object-fit: cover;" />
            }
            else
            {
                <div class="bg-light d-flex align-items-center justify-content-center rounded-4 shadow-sm mb-4" style="height: 400px;">
                    <i class="bi bi-cup-hot-fill fs-1 text-muted"></i>
                </div>
            }
        </div>
        <div class="col-md-6">
            <h1 class="fw-bold mb-4" style="color: #5d4037;">@Model.Name</h1>
            <div class="mb-4 p-4 bg-light rounded-4">
                <h3 class="text-danger fw-bold mb-3">@String.Format("{0:N0}", Model.Price)đ</h3>
                <p class="lead">@Html.Raw(Model.Description?.Replace("\n", "<br />"))</p>
            </div>
            <div class="d-flex gap-3">
                <a asp-action="Edit" asp-controller="Product" asp-route-id="@Model.Id" class="btn btn-warning w-100">
                    <i class="bi bi-pencil me-2"></i>Sửa thông tin
                </a>
                <a asp-action="Delete" asp-controller="Product" asp-route-id="@Model.Id" class="btn btn-outline-danger w-100">
                    <i class="bi bi-trash me-2"></i>Xóa món
                </a>
            </div>
        </div>
    </div>
    <div class="mt-5">
        <a asp-action="Index" class="btn btn-secondary">← Quay lại quản lý</a>
    </div>
</div>
