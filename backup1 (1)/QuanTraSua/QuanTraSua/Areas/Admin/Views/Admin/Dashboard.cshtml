@model IEnumerable<QuanTraSua.Models.Order>

@{
    ViewData["Title"] = "Doanh thu - Admin";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-uppercase" style="color: oklch(70.299% 0.16929 243.107);"> Doanh Thu</h2>
        <span class="badge bg-dark p-2">Cập nhật: @DateTime.Now.ToString("HH:mm dd/MM")</span>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 bg-primary text-white p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase opacity-75 small">Tổng đơn hàng</h6>
                        <h2 class="fw-bold mb-0">@ViewBag.TotalOrders</h2>
                    </div>
                    <i class="bi bi-cart-check fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 bg-success text-white p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase opacity-75 small">Doanh thu</h6>
                        <h2 class="fw-bold mb-0">@String.Format("{0:N0}", ViewBag.TotalRevenue)đ</h2>
                    </div>
                    <i class="bi bi-cash-stack fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 bg-warning text-dark p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase opacity-75 small">Sản phẩm đã bán</h6>
                        <h2 class="fw-bold mb-0">@ViewBag.TotalQuantity</h2>
                    </div>
                    <i class="bi bi-cup-hot fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white py-3 border-bottom">
            <h5 class="mb-0 fw-bold"><i class="bi bi-list-stars me-2"></i>Đơn hàng mới nhất</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Khách hàng</th>
                            <th>Liên hệ</th>
                            <th>Địa chỉ giao</th>
                            <th>Chi tiết món</th>
                            <th>Tổng tiền</th>
                            <th class="pe-4 text-end">Thời gian</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold">@item.CustomerName</div>
                                        <small class="text-muted">PTTT: @item.PaymentMethod</small>
                                    </td>
                                    <td>@item.Phone</td>
                                    <td style="max-width: 200px;" class="text-truncate">@item.Address</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">@item.OrderDetails</span>
                                    </td>
                                    <td class="fw-bold text-danger">@String.Format("{0:N0}", item.TotalPrice)đ</td>
                                    <td class="pe-4 text-end text-muted small">
                                        @item.OrderDate.ToString("HH:mm") <br> @item.OrderDate.ToString("dd/MM/yyyy")
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">Chưa có đơn hàng nào được đặt.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
