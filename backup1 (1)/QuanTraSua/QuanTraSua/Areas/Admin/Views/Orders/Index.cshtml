@model IEnumerable<QuanTraSua.Models.Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container mt-4">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 fw-bold"><i class="bi bi-receipt me-2"></i>DANH SÁCH ĐƠN HÀNG</h4>
            <div>
                <a href="/Admin/Dashboard" class="btn btn-outline-light btn-sm me-2">← Dashboard</a>
                <a href="/Admin/Logout" class="btn btn-danger btn-sm">Đăng xuất</a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr class="text-secondary">
                            <th class="ps-4">Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Địa chỉ và Liên hệ</th>
                            <th>Chi tiết món</th>
                            <th>Tổng tiền</th>
                            <th>Ngày đặt</th>
                            <th class="pe-4 text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">#@item.Id</td>
                                    <td>
                                        <div class="fw-bold">@item.CustomerName</div>
                                        <span class="badge bg-info text-dark" style="font-size: 0.7rem;">@item.PaymentMethod</span>
                                    </td>
                                    <td>
                                        <div><i class="bi bi-telephone me-1"></i>@item.Phone</div>
                                        <div class="text-muted small"><i class="bi bi-geo-alt me-1"></i>@item.Address</div>
                                    </td>
                                    <td>
                                        <div class="text-truncate" style="max-width: 200px;" title="@item.OrderDetails">
                                            @item.OrderDetails
                                        </div>
                                    </td>
                                    <td class="fw-bold text-danger">@String.Format("{0:N0}", item.TotalPrice)đ</td>
                                    <td class="small text-muted">
                                        @item.OrderDate.ToString("HH:mm") <br/> @item.OrderDate.ToString("dd/MM/yyyy")
                                    </td>
                                    <td class="pe-4 text-end">
                                        <a asp-action="Delete" asp-route-id="@item.Id" 
                                           class="btn btn-sm btn-outline-danger border-0" 
                                           onclick="return confirm('Bạn có chắc chắn muốn xóa đơn hàng này?')">
                                            <i class="bi bi-trash"></i> Xóa
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    Chưa có đơn hàng nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
