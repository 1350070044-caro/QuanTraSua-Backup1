@model List<QuanTraSua.Controllers.CartItem>
@{ ViewData["Title"] = "Giỏ hàng của bạn"; }

<div class="container mt-5">
    <h2 class="fw-bold mb-4" style="color: var(--dark-brown);">🛒 GIỎ HÀNG CỦA BẠN</h2>
    
    @if (Model.Count > 0) {
        <div class="row">
            <div class="col-md-8">
                <div class="card shadow-sm border-0 rounded-4 p-3">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Giá</th>
                                <th>Số lượng</th>
                                <th>Tổng</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model) {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="@item.ImageUrl" style="width:60px; height:60px; object-fit:cover" class="rounded-3 me-3">
                                            <span class="fw-bold">@item.ProductName</span>
                                        </div>
                                    </td>
                                    <td>@String.Format("{0:N0}", item.Price)đ</td>
                                    <td>@item.Quantity</td>
                                    <td class="fw-bold">@String.Format("{0:N0}", item.Price * item.Quantity)đ</td>
                                    <td><a href="/Cart/Remove/@item.ProductId" class="text-danger"><i class="bi bi-trash"></i> Xóa</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-0 rounded-4 p-4 bg-white">
                    <h4 class="fw-bold mb-4">Tóm tắt đơn hàng</h4>
                    <div class="d-flex justify-content-between fs-5 mb-4">
                        <span>Tổng tiền:</span>
                        <span class="fw-bold text-success">@String.Format("{0:N0}", ViewBag.Total)đ</span>
                    </div>
                    <a href="/Order/Create" class="btn btn-success btn-lg w-100 rounded-pill fw-bold" style="background-color: var(--milk-tea); border:none;">
                        TIẾN HÀNH THANH TOÁN
                    </a>
                    <a href="/Home/Menu" class="btn btn-outline-secondary w-100 rounded-pill mt-2">Tiếp tục mua sắm</a>
                </div>
            </div>
        </div>
    } else {
        <div class="text-center py-5">
            <h4 class="text-muted">Giỏ hàng đang trống!</h4>
            <a href="/Home/Menu" class="btn btn-custom mt-3 px-5 py-2">Quay lại Menu ngay</a>
        </div>
    }
</div>