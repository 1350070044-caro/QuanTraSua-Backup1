                    </div>
                </div>

                <div class="carousel-item">
                    <div class="row justify-content-center">
                        <div class="col-md-8 text-center">
                            <div class="mb-3">
                                <img src="https://ui-avatars.com/api/?name=Anh+Minh&background=random" class="rounded-circle shadow-sm" width="80" alt="Customer Avatar">
                            </div>
                            <div class="text-warning mb-2">
                                <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                            </div>
                            <p class="fst-italic fs-5 text-muted px-4">
                                "Trà sữa Oolong ở đây rất đỉnh, không quá ngọt, đúng gu mình. Nhân viên giao hàng nhiệt tình, đóng gói rất cẩn thận."
                            </p>
                            <h6 class="fw-bold mt-3 text-dark">ANH MINH / <span class="text-muted fw-normal">KH-100020555</span></h6>
                        </div>
                    </div>
                </div>
            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="prev">
                <i class="bi bi-chevron-left text-dark fs-1"></i>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="next">
                <i class="bi bi-chevron-right text-dark fs-1"></i>
            </button>

            <div class="carousel-indicators" style="bottom: 0;">
                <button type="button" data-bs-target="#testimonialCarousel" data-bs-slide-to="0" class="active bg-dark"></button>
                <button type="button" data-bs-target="#testimonialCarousel" data-bs-slide-to="1" class="bg-dark"></button>
            </div>
        </div>
    </div>
</section>

<style>
    /* Chỉnh sửa nút điều hướng cho đẹp hơn */
    #testimonialCarousel .carousel-control-prev, 
    #testimonialCarousel .carousel-control-next {
        width: 5%;
        opacity: 1;
    }
    #testimonialCarousel .carousel-indicators [data-bs-target] {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin: 0 5px;
    }
    #testimonialCarousel p {
        line-height: 1.6;
        max-width: 700px;
        margin: 0 auto;
    }
</style>

