@model QuanTraSua.Models.Order
@{
    ViewData["Title"] = "Thanh toán đơn hàng";
    var cart = ViewBag.Cart as List<QuanTraSua.Controllers.CartItem>;
}

<div class="container mt-5 mb-5">
    <div class="row g-5">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm p-4 rounded-4 bg-white">
                <h4 class="fw-bold mb-4" style="color: #5d4037;"> Thông tin giao hàng</h4>
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-bold">Họ và tên khách hàng</label>
                            <input asp-for="CustomerName" class="form-control rounded-pill border-2" placeholder="Ví dụ: Nguyễn Văn A" />
                            <span asp-validation-for="CustomerName" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <input asp-for="Phone" class="form-control rounded-pill border-2" placeholder="0901234567" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Email (không bắt buộc)</label>
                            <input asp-for="Email" class="form-control rounded-pill border-2" placeholder="email@gmail.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-12">
                            <label class="form-label fw-bold">Địa chỉ giao hàng</label>
                            <input asp-for="Address" class="form-control rounded-pill border-2" placeholder="Số nhà, tên đường..." />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-12">
                            <label class="form-label fw-bold">Ghi chú</label>
                            <textarea asp-for="Note" class="form-control rounded-4 border-2" rows="3" placeholder="Ghi chú thêm về đơn hàng..."></textarea>
                        </div>
                    </div>
                    <h4 class="fw-bold mt-5 mb-4" style="color: #5d4037;"> Phương thức thanh toán</h4>
                    <div class="mb-4">
                        <select asp-for="PaymentMethod" class="form-select rounded-pill border-2 py-2">
                            <option value="COD">Thanh toán khi nhận hàng (COD)</option>
                            <option value="Bank">Chuyển khoản ngân hàng</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-success btn-lg w-100 rounded-pill fw-bold py-3 shadow" style="background-color: #165d3a; border:none;">
                         XÁC NHẬN ĐẶT HÀNG
                    </button>
                </form>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card border-0 shadow-sm p-4 rounded-4 bg-white position-sticky" style="top: 20px;">
                <h4 class="fw-bold mb-4" style="color: #5d4037;"> Đơn hàng của bạn</h4>
                
                @if (cart != null && cart.Any())
                {
                    <div class="order-items mb-4">
                        @foreach (var item in cart)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h6 class="mb-0 fw-bold">@item.ProductName</h6>
                                    <small class="text-muted">Số lượng: @item.Quantity</small>
                                </div>
                                <span class="fw-bold">@String.Format("{0:N0}", item.Price * item.Quantity)đ</span>
                            </div>
                        }
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tạm tính:</span>
                        <span class="fw-bold">@String.Format("{0:N0}", ViewBag.Total)đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Phí vận chuyển:</span>
                        <span class="fw-bold text-success">20,000đ</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <h5 class="fw-bold">Tổng cộng:</h5>
                        <h4 class="fw-bold text-danger">@String.Format("{0:N0}", (decimal)ViewBag.Total + 20000)đ</h4>
                    </div>
                }
                else
                {
                    <p class="text-center text-muted">Giỏ hàng trống.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}