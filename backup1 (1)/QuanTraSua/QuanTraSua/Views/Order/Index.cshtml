@model IEnumerable<QuanTraSua.Models.Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng - Admin";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-11">
            <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
                <div class="card-header bg-gradient text-white py-4 d-flex justify-content-between align-items-center position-relative">
                    <div>
                        <i class="bi bi-receipt-cutoff fs-2 me-3 opacity-75"></i>
                        <h2 class="mb-0 fw-bold d-inline">QUẢN LÝ ĐƠN HÀNG</h2>
                        <small class="d-block mt-1 opacity-75">@(Model?.Count() ?? 0) đơn hàng</small>
                    </div>
                    <div class="position-relative">
                        <a href="/Admin/Dashboard" class="btn btn-light btn-lg px-4 shadow-sm me-2">
                            <i class="bi bi-arrow-left me-1"></i> Dashboard
                        </a>
                        <a href="/Admin/Logout" class="btn btn-outline-light btn-lg px-4 shadow-sm">
                            <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                        </a>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-borderless mb-0">
                            <thead class="table-dark table-group-divider">
                                <tr>
                                    <th class="ps-4 py-3">#</th>
                                    <th class="py-3">Khách hàng</th>
                                    <th class="py-3">Liên hệ</th>
                                    <th class="py-3">Chi tiết</th>
                                    <th class="py-3 text-end">Tiền</th>
                                    <th class="py-3 text-end">Thời gian</th>
                                    <th class="py-3 pe-4 text-end">Hành động</th>
                                </tr>
                            </thead>
                            <tbody class="table-group-divider">
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr class="hover-shadow">
                                            <td class="ps-4 fw-bold fs-5 text-primary" style="width: 80px;">
                                                #@item.Id
                                            </td>
                                            <td class="align-middle">
                                                <div class="fw-bolder h6 mb-1">@item.CustomerName</div>
                                                <span class="badge rounded-pill bg-success bg-opacity-75 px-3 py-1">@item.PaymentMethod</span>
                                            </td>
                                            <td class="align-middle">
                                                <div class="fw-medium mb-1">@item.Phone</div>
                                                <div class="text-muted small">
                                                    <i class="bi bi-geo-alt-fill me-1"></i>
                                                    @(string.IsNullOrEmpty(item.Address) ? "" : item.Address.Split(',')[0] + "...")
                                                </div>
                                            </td>
                                            <td class="align-middle">
                                                <div class="rounded-3 p-2 bg-light mb-1" style="max-height: 60px; overflow-y: auto; font-size: 0.875rem;">
                                                    @item.OrderDetails
                                                </div>
                                            </td>
                                            <td class="align-middle text-end fw-bold fs-5 text-success">
                                                @item.TotalPrice.ToString("N0")<span class="text-muted fs-6">đ</span>
                                            </td>
                                            <td class="align-middle text-end text-muted">
                                                <div class="fw-medium">@item.OrderDate.ToString("HH:mm")</div>
                                                <div class="small">@item.OrderDate.ToString("dd/MM")</div>
                                            </td>
                                            <td class="align-middle text-end pe-4">
                                                <div class="btn-group" role="group">
                                                    <button class="btn btn-sm btn-outline-secondary border-0" onclick="printOrder(@item.Id)" title="In đơn">
                                                        <i class="bi bi-printer"></i>
                                                    </button>
                                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger border-0" onclick="return confirm('Xóa đơn #@item.Id?')">
                                                        <i class="bi bi-trash3-fill"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-5">
                                            <i class="bi bi-receipt fs-1 text-muted mb-3 d-block"></i>
                                            <h5 class="text-muted mb-1">Chưa có đơn hàng</h5>
                                            <p class="text-muted mb-4">Đợi khách đặt hàng đầu tiên...</p>
                                            <a href="/Home/Menu" class="btn btn-primary px-4">Xem thực đơn</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-light py-3 text-center">
                    <small class="text-muted">Cập nhật @DateTime.Now.ToString("HH:mm:ss dd/MM/yyyy")</small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.hover-shadow:hover { 
    transform: translateY(-2px); 
    box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important; 
    transition: all 0.2s ease; 
}
.bg-gradient { 
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); 
}
</style>

<script>
function printOrder(id) {
    Swal.fire({
        title: 'In đơn hàng',
        text: 'Chức năng in sẽ được thêm sau!',
        icon: 'info'
    });
}
</script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
