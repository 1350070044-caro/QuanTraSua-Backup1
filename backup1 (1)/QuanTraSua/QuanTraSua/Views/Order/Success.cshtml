@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container mt-5 mb-5 text-center">
    <div class="card shadow-lg border-0 rounded-5 p-5 bg-white">
        <div class="mb-4">
            <div class="display-1 text-success animate__animated animate__bounceIn">
                <i class="bi bi-check-circle-fill"></i>
            </div>
        </div>
        
        <h2 class="fw-bold mb-3" style="color: #5d4037;"> ĐẶT HÀNG THÀNH CÔNG!</h2>
        <p class="text-muted fs-5">
            Cảm ơn bạn đã ủng hộ quán. Đơn hàng của bạn đã được tiếp nhận và đang trong quá trình chuẩn bị.
        </p>
        
        <div class="alert alert-warning d-inline-block px-4 py-2 rounded-pill mb-4">
            <i class="bi bi-truck me-2"></i> Shipper sẽ sớm liên hệ với bạn qua số điện thoại đã cung cấp!
        </div>

        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <a href="/" class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm" style="background-color: #C89F7C; border: none;">
                <i class="bi bi-house-door me-2"></i> Quay lại trang chủ
            </a>
            <a href="/Home/Menu" class="btn btn-outline-secondary btn-lg px-5 rounded-pill">
                Tiếp tục mua sắm
            </a>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body { background-color: #f8f9fa; }
    .card { max-width: 600px; margin: 0 auto; }
</style>